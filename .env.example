# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=
APP_URL=

# Google Sheets integration — set to a Spreadsheet ID or full Google Sheets URL.
# When present, the dashboard auto-connects to this sheet on load instead of
# showing demo data.  Works with any Google Sheets URL format or a bare ID.
# Example: VITE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OdiFi2ow
VITE_SHEET_ID=
